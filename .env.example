# ===== LINE BOT CONFIG =====
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_TOKEN=your_channel_access_token_here

# ===== GOOGLE SHEETS CONFIG =====
# ID ของ Google Sheets ดูจาก URL: docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# ===== ADMIN CONFIG =====
# LINE User ID ของ Admin (หาได้โดยพิมพ์ /whoami ใน LINE)
# ใส่หลายคนโดยคั่นด้วย comma: U123abc,U456def
ADMIN_LINE_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== GOOGLE SERVICE ACCOUNT (สำหรับเขียนข้อมูลลง Sheets) =====
# วิธีตั้งค่า:
# 1. ไปที่ https://console.cloud.google.com
# 2. Enable "Google Sheets API"
# 3. IAM → Service Accounts → Create → Create Key (JSON)
# 4. Share Google Sheets กับ email ของ Service Account เป็น Editor
# 5. ใส่ค่าจากไฟล์ JSON ที่ดาวน์โหลดมา:
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIB...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your_client_id

# ===== SERVER CONFIG =====
PORT=3000
